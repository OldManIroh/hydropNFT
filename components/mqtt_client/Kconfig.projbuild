menu "Настройки MQTT"

    config MQTT_BROKER_URI
        string "URI брокера"
        default "mqtt://192.168.0.107:1883"
        help
            Адрес MQTT брокера для подключения.
            Примеры: mqtt://192.168.0.107:1883, mqtts://broker.example.com:8883

    config MQTT_USERNAME
        string "Имя пользователя"
        default "hydroesp32"
        help
            Имя пользователя для аутентификации на MQTT брокере.

    config MQTT_PASSWORD
        string "Пароль"
        default "asda"
        help
            Пароль для аутентификации на MQTT брокере.
            Внимание: хранится в открытом виде в конфигурации.

    config LIGHT_ON_HOUR
        int "Час включения света"
        default 8
        range 0 23
        help
            Час (0–23), в который включается свет по расписанию.

endmenu
