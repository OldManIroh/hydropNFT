menu "Настройки OTA обновления"

    config EXAMPLE_FIRMWARE_UPG_URL
        string "URL прошивки"
        default "https://example.com/firmware.bin"
        help
            HTTPS URL для загрузки новой прошивки.

    config EXAMPLE_OTA_RECV_TIMEOUT
        int "Таймаут получения данных (мс)"
        default 60000
        help
            Таймаут получения данных OTA в миллисекундах.
            Увеличьте при медленном Wi-Fi соединении.

    config EXAMPLE_GPIO_DIAGNOSTIC
        int "GPIO пин диагностики"
        default 34
        help
            GPIO пин для проверки работоспособности после OTA обновления.

            Внимание: не используйте GPIO 0 (кнопка BOOT) или GPIO 2 (встроенный LED).
            Рекомендуемые пины: GPIO 34, 35, 36, 39 — только вход, без внутренних подтяжек.
            По умолчанию GPIO 34.

endmenu
