menu "OTA Client Configuration"

config EXAMPLE_FIRMWARE_UPG_URL
    string "Firmware Upgrade URL"
    default "https://example.com/firmware.bin"
    help
        URL для загрузки прошивки

config EXAMPLE_OTA_RECV_TIMEOUT
    int "OTA Receive Timeout (ms)"
    default 60000
    help
        Таймаут получения данных OTA (увеличен до 60 сек для медленного Wi-Fi)

config EXAMPLE_GPIO_DIAGNOSTIC
    int "GPIO for Diagnostic"
    default 34
    help
        GPIO пин для диагностики после OTA.

        WARNING: Не используйте GPIO 0 (BOOT кнопка) или GPIO 2 (встроенный LED).
        Рекомендуется использовать GPIO 34, 35, 36, 39 (только вход, нет подтяжек).

        По умолчанию GPIO 34 - вход без подтяжки, конфликт с BOOT исключён.

config EXAMPLE_CONNECT_WIFI
    bool "Connect using Wi-Fi"
    default y
    help
        Использовать Wi-Fi для подключения

endmenu
