menu "Настройки оборудования"

    config PUMP_GPIO
        int "GPIO пин насоса"
        default 19
        help
            Номер GPIO пина для управления насосом.

    config LIGHT_GPIO
        int "GPIO пин света"
        default 18
        help
            Номер GPIO пина для управления светом (фитолампа).

    config VALVE_GPIO
        int "GPIO пин клапана"
        default 4
        help
            Номер GPIO пина для управления клапаном.

    config VALVE_DRAIN_DURATION_MIN
        int "Время слива воды (минуты)"
        default 5
        range 1 30
        help
            Длительность слива воды через клапан в минутах.
            Используется в автоматическом режиме DRAINING.

endmenu

menu "Настройки датчика DHT"

    choice EXAMPLE_CHIP_TYPE
        prompt "Тип датчика"
        default EXAMPLE_TYPE_AM2301

        config EXAMPLE_TYPE_DHT11
            bool "DHT11"
        config EXAMPLE_TYPE_AM2301
            bool "DHT21 / DHT22 / AM2301 / AM2302 / AM2321"
        config EXAMPLE_TYPE_SI7021
            bool "Itead Si7021"
    endchoice

    config EXAMPLE_DATA_GPIO
        int "GPIO пин данных"
        default 4 if IDF_TARGET_ESP8266
        default 4 if IDF_TARGET_ESP32C2 || IDF_TARGET_ESP32C3 || IDF_TARGET_ESP32C5 || IDF_TARGET_ESP32C6 || IDF_TARGET_ESP32C61
        default 4 if IDF_TARGET_ESP32H2
        default 4 if IDF_TARGET_ESP32P4
        default 17 if IDF_TARGET_ESP32 || IDF_TARGET_ESP32S2 || IDF_TARGET_ESP32S3
        help
            Номер GPIO пина, подключённого к выводу DATA датчика.

    config EXAMPLE_INTERNAL_PULLUP
        bool "Внутренний pull-up резистор"
        default n
        help
            Включите, если на пине данных нет внешнего pull-up резистора.
            Датчики DHT на печатной плате обычно имеют встроенный pull-up.
            Для стабильной работы рекомендуется внешний резистор 10 кОм.

endmenu

menu "Настройки точки доступа (AP)"

    config AP_WIFI_PASSWORD
        string "Пароль точки доступа"
        default "hydronft12345678"
        help
            Пароль WPA2 для точки доступа HydroNFT_XXYY.
            Минимум 8 символов. Используется для защиты
            веб-интерфейса при подключении напрямую к устройству.

endmenu
